---
import type { ExperienceDict } from "@/lib/dict/types";

interface Props {
  dict: ExperienceDict;
}

const { dict } = Astro.props;
const { entries } = dict;
const groupName = "experience-tabs";
const css = entries.map((_, index) => `
  #experience-${index}:checked ~ .experience-shell .experience-tab-${index},
  #experience-${index}:checked ~ .experience-shell .experience-dot-${index} {
    color: var(--primary);
    border-color: var(--primary);
    background: color-mix(in oklch, var(--primary) 5%, transparent);
  }

  #experience-${index}:checked ~ .experience-shell .experience-dot-${index} {
    width: 1rem;
    background: var(--primary);
  }

  #experience-${index}:checked ~ .experience-shell .experience-panel-${index} {
    opacity: 1;
    transform: translateY(0);
    z-index: 10;
    pointer-events: auto;
    transition-duration: 500ms;
    transition-delay: 200ms;
  }

  #experience-${index}:checked ~ .experience-shell .experience-mobile-title-${index},
  #experience-${index}:checked ~ .experience-shell .experience-prev-${index},
  #experience-${index}:checked ~ .experience-shell .experience-next-${index} {
    display: inline-flex;
  }
`).join("\n");
---

<section id="experience" class="py-24 px-6 md:px-12 lg:px-24">
  <div class="max-w-4xl mx-auto">
    <div class="anim-scroll-fade">
      <h2 class="flex items-center gap-4 text-2xl md:text-3xl font-bold text-foreground mb-12">
        <span class="text-primary font-mono text-lg">{dict.sectionNumber}</span>
        {dict.title}
        <span class="h-px bg-border flex-1 max-w-xs"></span>
      </h2>
    </div>

    {entries.map((_, index) => (
      <input class="experience-radio sr-only" type="radio" name={groupName} id={`experience-${index}`} checked={index === 0} />
    ))}

    <div class="experience-shell flex flex-col md:flex-row gap-8 anim-scroll-fade-delay-1">
      <div class="flex md:hidden items-center justify-between gap-2 border-b border-border pb-4">
        <div class="w-10 flex justify-start">
          {entries.map((_, index) => (
            index === 0 ? (
              <span class={`experience-prev-${index} hidden p-2 rounded-lg text-muted-foreground/30 cursor-not-allowed`} aria-label={dict.ariaLabelPrev} aria-disabled="true">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6" /></svg>
              </span>
            ) : (
              <label for={`experience-${index - 1}`} class={`experience-prev-${index} hidden p-2 rounded-lg transition-all text-primary hover:bg-primary/10 cursor-pointer`} aria-label={dict.ariaLabelPrev}>
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6" /></svg>
              </label>
            )
          ))}
        </div>

        <div class="flex-1 text-center">
          {entries.map((entry, index) => (
            <span class={`experience-mobile-title-${index} hidden text-sm font-mono text-primary`}>{entry.company}</span>
          ))}
          <div class="flex justify-center gap-1.5 mt-2">
            {entries.map((entry, index) => (
              <label
                for={`experience-${index}`}
                class={`experience-dot-${index} block w-2 h-2 rounded-full transition-all bg-muted-foreground/30 hover:bg-muted-foreground/50 cursor-pointer`}
                aria-label={`${dict.ariaLabelGoto} ${entry.company}`}
              ></label>
            ))}
          </div>
        </div>

        <div class="w-10 flex justify-end">
          {entries.map((_, index) => (
            index === entries.length - 1 ? (
              <span class={`experience-next-${index} hidden p-2 rounded-lg text-muted-foreground/30 cursor-not-allowed`} aria-label={dict.ariaLabelNext} aria-disabled="true">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6" /></svg>
              </span>
            ) : (
              <label for={`experience-${index + 1}`} class={`experience-next-${index} hidden p-2 rounded-lg transition-all text-primary hover:bg-primary/10 cursor-pointer`} aria-label={dict.ariaLabelNext}>
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6" /></svg>
              </label>
            )
          ))}
        </div>
      </div>

      <div class="hidden md:flex md:flex-col md:border-l border-border" role="tablist" aria-label={dict.title}>
        {entries.map((exp, index) => (
          <label
            for={`experience-${index}`}
            class={`experience-tab-${index} px-4 py-3 text-sm font-mono whitespace-nowrap text-left transition-all hover:bg-primary/10 hover:text-primary md:border-l-2 md:-ml-px text-muted-foreground border-transparent cursor-pointer`}
            role="tab"
          >
            {exp.company}
          </label>
        ))}
      </div>

      <div class="flex-1 min-h-[300px] grid">
        {entries.map((exp, index) => (
          <article class={`experience-panel-${index} space-y-4 col-start-1 row-start-1 opacity-0 translate-y-4 pointer-events-none -z-10 transition-all ease-out duration-200`}>
            <h3 class="text-xl font-semibold text-foreground">
              {exp.role} <span class="text-primary">@ {exp.company}</span>
            </h3>
            <p class="text-sm font-mono text-muted-foreground">{exp.period}</p>
            <p class="text-muted-foreground leading-relaxed">{exp.summary}</p>
            <ul class="space-y-3">
              {exp.bullets.map((item) => (
                <li class="flex gap-3 text-muted-foreground leading-relaxed">
                  <span class="text-primary mt-1.5">▹</span>
                  {item}
                </li>
              ))}
            </ul>
            <div class="flex flex-wrap gap-2 pt-4">
              {exp.technologies.map((tech) => (
                <span class="px-3 py-1 text-xs font-mono text-primary bg-primary/10 rounded-full">{tech}</span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style is:inline set:html={css}></style>

---
import type { NavDict } from "@/lib/dict/types";
import type { Locale } from "@/lib/dict";

interface Props {
  dict: NavDict;
  locale: Locale;
  otherLocalePath: string;
}

const { dict, locale, otherLocalePath } = Astro.props;
const cvUrl = locale === "es" ? "/cv.pdf" : "/resume.pdf";
const cvFilename = locale === "es" ? "agustin-mariscotti-cv.pdf" : "agustin-mariscotti-resume.pdf";
const navItemClasses = [
  "anim-nav-item-1",
  "anim-nav-item-2",
  "anim-nav-item-3",
  "anim-nav-item-4",
  "anim-nav-item-5",
];
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 anim-nav-slide bg-background/80 backdrop-blur-md border-b border-border">
  <nav class="max-w-7xl mx-auto px-6 md:px-12 lg:px-24 h-16 flex items-center justify-between">
    <a href="#" class="flex items-center hover:opacity-80 transition-opacity" aria-label="Home">
      <img src="/favicon-32x32.png" alt="AM Logo" class="w-8 h-8 rounded-sm" />
    </a>

    <div class="hidden md:flex items-center gap-8">
      {dict.items.map((item, index) => (
        <a
          href={item.href}
          class={`text-sm text-muted-foreground hover:text-primary transition-colors ${navItemClasses[index] ?? ""}`}
          data-umami-event="nav_click"
          data-umami-event-section={item.label.toLowerCase()}
          data-umami-event-index={String(index + 1)}
        >
          <span class="text-primary font-mono text-xs mr-1">0{index + 1}.</span>
          {item.label}
        </a>
      ))}

      <div class="anim-nav-item-5">
        <div class="text-sm font-mono flex items-center gap-1">
          {locale === "es" ? (
            <span class="text-primary font-semibold">ES</span>
          ) : (
            <a
              href={otherLocalePath}
              class="text-muted-foreground hover:text-primary transition-colors"
              data-umami-event="language_switch"
              data-umami-event-from="en"
              data-umami-event-to="es"
            >ES</a>
          )}
          <span class="text-muted-foreground/40 mx-0.5">|</span>
          {locale === "en" ? (
            <span class="text-primary font-semibold">EN</span>
          ) : (
            <a
              href={otherLocalePath}
              class="text-muted-foreground hover:text-primary transition-colors"
              data-umami-event="language_switch"
              data-umami-event-from="es"
              data-umami-event-to="en"
            >EN</a>
          )}
        </div>
      </div>

      <div class="anim-nav-item-6">
        <a
          href={cvUrl}
          download={cvFilename}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-1.5 whitespace-nowrap rounded-md text-sm font-medium transition-all border bg-background shadow-xs hover:bg-accent hover:text-accent-foreground h-8 px-3"
          data-umami-event="cv_download"
          data-umami-event-locale={locale}
        >
          {dict.cvLabel}
        </a>
      </div>
    </div>

    <button id="mobile-menu-open" type="button" class="md:hidden text-foreground p-2" aria-label={dict.ariaLabelOpenMenu} aria-controls="mobile-menu" aria-expanded="false">
      <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 12h16" />
        <path d="M4 6h16" />
        <path d="M4 18h16" />
      </svg>
    </button>
  </nav>
</header>

<div id="mobile-menu" data-open="false" class="fixed inset-0 z-40 md:hidden opacity-0 pointer-events-none transition-all duration-300">
  <button id="mobile-menu-overlay" type="button" class="absolute inset-0 bg-background/80 backdrop-blur-md" aria-label={dict.ariaLabelCloseMenu}></button>
  <nav class="absolute right-0 top-0 bottom-0 w-3/4 max-w-sm bg-card border-l border-border p-8 pt-24 flex flex-col gap-6 translate-x-full transition-transform duration-300 mobile-menu-panel">
    <button id="mobile-menu-close" type="button" class="absolute top-5 right-6 p-2 text-foreground" aria-label={dict.ariaLabelCloseMenu}>
      <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 6 6 18" />
        <path d="m6 6 12 12" />
      </svg>
    </button>

    {dict.items.map((item, index) => (
      <a
        href={item.href}
        class="text-lg text-foreground hover:text-primary transition-colors"
        data-umami-event="nav_click"
        data-umami-event-section={item.label.toLowerCase()}
        data-umami-event-index={String(index + 1)}
      >
        <span class="text-primary font-mono text-sm mr-2">0{index + 1}.</span>
        {item.label}
      </a>
    ))}

    <div class="text-base font-mono flex items-center gap-1 pt-2 border-t border-border">
      {locale === "es" ? (
        <span class="text-primary font-semibold">ES</span>
      ) : (
        <a href={otherLocalePath} class="text-muted-foreground hover:text-primary transition-colors" data-umami-event="language_switch" data-umami-event-from="en" data-umami-event-to="es">ES</a>
      )}
      <span class="text-muted-foreground/40 mx-0.5">|</span>
      {locale === "en" ? (
        <span class="text-primary font-semibold">EN</span>
      ) : (
        <a href={otherLocalePath} class="text-muted-foreground hover:text-primary transition-colors" data-umami-event="language_switch" data-umami-event-from="es" data-umami-event-to="en">EN</a>
      )}
    </div>

    <a
      href={cvUrl}
      download={cvFilename}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center gap-1.5 whitespace-nowrap rounded-md text-sm font-medium transition-all border bg-background shadow-xs hover:bg-accent hover:text-accent-foreground h-8 px-3"
      data-umami-event="cv_download"
      data-umami-event-locale={locale}
    >
      {dict.cvLabel}
    </a>
  </nav>
</div>

<style>
  #mobile-menu[data-open="true"] {
    opacity: 1;
    pointer-events: auto;
  }

  #mobile-menu[data-open="true"] .mobile-menu-panel {
    translate: 0;
    transform: translateX(0);
  }
</style>

<script>
  const mobileMenu = document.querySelector<HTMLElement>("#mobile-menu");
  const openButton = document.querySelector<HTMLButtonElement>("#mobile-menu-open");
  const closeButton = document.querySelector<HTMLButtonElement>("#mobile-menu-close");
  const overlayButton = document.querySelector<HTMLButtonElement>("#mobile-menu-overlay");
  const mobileMenuLinks = mobileMenu?.querySelectorAll<HTMLAnchorElement>("a[href]");

  const setMobileMenuOpen = (open: boolean) => {
    mobileMenu?.setAttribute("data-open", String(open));
    openButton?.setAttribute("aria-expanded", String(open));
    document.body.style.overflow = open ? "hidden" : "";
  };

  openButton?.addEventListener("click", () => {
    setMobileMenuOpen(mobileMenu?.getAttribute("data-open") !== "true");
  });
  closeButton?.addEventListener("click", () => setMobileMenuOpen(false));
  overlayButton?.addEventListener("click", () => setMobileMenuOpen(false));
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      setMobileMenuOpen(false);
    }
  });
  mobileMenuLinks?.forEach((link) => {
    link.addEventListener("click", () => setMobileMenuOpen(false));
  });
</script>
